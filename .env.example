# --- Dashboard ---
# PostgreSQL connection string (required — the Prisma provider is postgresql).
DATABASE_URL="postgresql://homelab:CHANGE_ME@localhost:5432/homelab?schema=public"

# Optional: only used by the integration test suite (npm run test:integration).
# Point it at a Postgres you don't mind a throwaway schema being created in.
# Without it the integration suite skips cleanly.
# TEST_DATABASE_URL="postgresql://homelab:CHANGE_ME@localhost:5432/homelab"

# Public app URL (used for clients and CORS-aware features later).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Reverse proxy (Fase 4 — deploy/fase-4-traefik-https.md) ---
# Hostname Traefik routes the dashboard on. With Tailscale Serve this is the
# Docker LXC's tailnet name, e.g. docker.<your-tailnet>.ts.net. Only needed
# when running with deploy/docker-compose.labels.yml.
DASHBOARD_HOST=""
# Only for the Let's Encrypt DNS-01 path with an own domain (Cloudflare shown).
CF_DNS_API_TOKEN=""

# --- Fase 5 services (deploy/fase-5-services.md) ---
# Vaultwarden. DB password matches the postgres user on CT 100; admin token is
# an argon2 hash (docker run --rm vaultwarden/server /vaultwarden hash).
VAULTWARDEN_DB_PASSWORD=""
VAULTWARDEN_ADMIN_TOKEN=""
# Full https URL clients use, and the bare host Traefik routes on (usually the
# Docker LXC's tailnet name, e.g. docker.<your-tailnet>.ts.net).
VAULTWARDEN_DOMAIN=""
VAULTWARDEN_HOST=""

# Nextcloud (Fase 6). DB password matches the nextcloud role you create on the
# shared Postgres (CT 100); the admin user/pass seed the first-run installer.
NEXTCLOUD_DB_PASSWORD=""
NEXTCLOUD_ADMIN_USER="admin"
NEXTCLOUD_ADMIN_PASSWORD=""

# --- Fase 7 services (deploy/fase-7-services.md) ---
# Shared by the linuxserver.io images (*arr stack, Kavita, speedtest). Defaults
# to 1000:1000; chown /mnt/media to match (see runbook) or set 0:0 for a quick
# start. TZ is used by most Fase-7 containers.
PUID="1000"
PGID="1000"
TZ="Europe/Amsterdam"

# Paperless-ngx. SECRET_KEY: openssl rand -base64 48. Admin creds seed the first
# account (the UI login).
PAPERLESS_SECRET_KEY=""
PAPERLESS_ADMIN_USER="mike"
PAPERLESS_ADMIN_PASSWORD=""

# speedtest-tracker. Laravel APP_KEY — MUST start with "base64:".
# Generate: echo "base64:$(openssl rand -base64 32)"
SPEEDTEST_APP_KEY=""

# Shared secret each agent must send in the X-Agent-Key header.
# Generate with: openssl rand -hex 32
AGENT_API_KEY="replace-with-a-long-random-string"

# Optional. If set, the offline-detection sweep route requires this in the
# x-sweep-key header. Leave unset if you only ever call it from the dashboard
# host itself behind a VPN.
SWEEP_KEY=""

# Optional quiet hours (local time, "HH:MM", may wrap midnight). During this
# window only CRITICAL alerts are pushed to notification channels; warnings are
# still recorded, just not sent until the window ends. Unset = always notify.
QUIET_HOURS_START=""
QUIET_HOURS_END=""

# Electricity price (€/kWh) for the rough monthly power-cost estimate shown on
# the server detail page (host power comes from the agent's RAPL reading).
POWER_PRICE_EUR_PER_KWH="0.34"

# Optional public, read-only status page at /status/<token> (no login). Set a
# long random token to enable it; leave empty to disable (404). It exposes only
# names + up/down. Generate with: openssl rand -hex 16
STATUS_PAGE_TOKEN=""

# --- Agent (used only inside /agent) ---
# URL the agent posts check-ins to.
DASHBOARD_URL="http://localhost:3000"

# Must match AGENT_API_KEY above.
# AGENT_API_KEY="replace-with-a-long-random-string"

# Friendly server name reported by the agent. Defaults to hostname if omitted.
AGENT_SERVER_NAME=""

# How often the agent reports metrics, in seconds (minimum 5).
AGENT_INTERVAL_SECONDS="30"

# Hard timeout on every outbound request to the dashboard, in seconds (2–120).
AGENT_REQUEST_TIMEOUT_SECONDS="15"

# Directory scanned for vzdump* archives to report backup freshness (Linux).
# Defaults to /tank/backups/dump. Only meaningful on the host that holds backups.
# AGENT_BACKUP_DIR="/tank/backups/dump"

# Optional SNMP polling of a managed switch. DORMANT unless AGENT_SNMP_TARGET is
# set; then the agent polls that IP over SNMP v2c each tick (Network page).
# AGENT_SNMP_TARGET="192.168.1.2"
# AGENT_SNMP_COMMUNITY="public"
