# --- Dashboard ---
# Choose ONE:
#   SQLite (default, zero-config):
DATABASE_URL="file:./prisma/dev.db"
#   Postgres:
# DATABASE_URL="postgresql://homelab:CHANGE_ME@localhost:5432/homelab?schema=public"

# Only used by docker-compose.postgres.yml. Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=""

# Public app URL (used for clients and CORS-aware features later).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Reverse proxy (Fase 4 — deploy/fase-4-traefik-https.md) ---
# Hostname Traefik routes the dashboard on. With Tailscale Serve this is the
# Docker LXC's tailnet name, e.g. docker.<your-tailnet>.ts.net. Only needed
# when running with deploy/docker-compose.labels.yml.
DASHBOARD_HOST=""
# Only for the Let's Encrypt DNS-01 path with an own domain (Cloudflare shown).
CF_DNS_API_TOKEN=""

# --- Fase 5 services (deploy/fase-5-services.md) ---
# Vaultwarden. DB password matches the postgres user on CT 100; admin token is
# an argon2 hash (docker run --rm vaultwarden/server /vaultwarden hash).
VAULTWARDEN_DB_PASSWORD=""
VAULTWARDEN_ADMIN_TOKEN=""
# Full https URL clients use, and the bare host Traefik routes on (usually the
# Docker LXC's tailnet name, e.g. docker.<your-tailnet>.ts.net).
VAULTWARDEN_DOMAIN=""
VAULTWARDEN_HOST=""

# Shared secret each agent must send in the X-Agent-Key header.
# Generate with: openssl rand -hex 32
AGENT_API_KEY="replace-with-a-long-random-string"

# Optional. If set, the offline-detection sweep route requires this in the
# x-sweep-key header. Leave unset if you only ever call it from the dashboard
# host itself behind a VPN.
SWEEP_KEY=""

# --- Agent (used only inside /agent) ---
# URL the agent posts check-ins to.
DASHBOARD_URL="http://localhost:3000"

# Must match AGENT_API_KEY above.
# AGENT_API_KEY="replace-with-a-long-random-string"

# Friendly server name reported by the agent. Defaults to hostname if omitted.
AGENT_SERVER_NAME=""

# How often the agent reports metrics, in seconds.
AGENT_INTERVAL_SECONDS="30"
