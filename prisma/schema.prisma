// Homelab Control Center — Prisma schema
// SQLite is used for the MVP because it is zero-config and good enough for a
// homelab dashboard. To migrate to Postgres later: change `provider` to
// "postgresql" and re-run `prisma migrate dev`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Server status is one of: "online" | "offline" | "warning" | "critical".
// Alert severity is one of: "info" | "warning" | "critical".
// Stored as plain strings because SQLite has no native enum type — values are
// validated at the API layer via Zod schemas.

model Server {
  id         String    @id @default(cuid())
  name       String
  hostname   String    @unique
  ipAddress  String?
  os         String?
  status     String    @default("offline")
  lastSeenAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  metrics       Metric[]
  metricsHourly MetricHourly[]
  containers    Container[]
  alerts        Alert[]
  jobs          Job[]
}

// Job is a command the dashboard wants an agent to execute on a host. The
// dashboard inserts a row with status="pending"; the agent for that host
// claims it (status→"inflight") and later reports back (status→"done"|"error").
// This is how the dashboard performs container actions without ever touching
// Docker directly. See AGENTS.md → "Future Docker control flow".
//
// type values (one of):
//   "container.start" | "container.stop" | "container.restart" | "container.logs"
//
// payload / result are JSON strings; consumers must JSON.parse.
// Job statuses:
//   pending   — enqueued, no agent claimed it yet
//   inflight  — claimed and being executed
//   done      — agent reported success
//   error     — agent reported failure
//   cancel    — dashboard asked the agent to stop (long-running streams only)
//
// `cancel` is a control-plane signal: when the agent next tries to post a
// chunk we return continue=false and it tears down the process. Once the
// agent acknowledges, it sets the final status to "done".
model Job {
  id          String    @id @default(cuid())
  serverId    String
  type        String
  payload     String    @default("{}")
  status      String    @default("pending")
  result      String?
  createdAt   DateTime  @default(now())
  claimedAt   DateTime?
  completedAt DateTime?

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  chunks LogChunk[]

  @@index([serverId, status, createdAt])
}

// Buffered output from a streaming job (currently only container.logs.stream).
// The SSE endpoint reads new rows by `seq` and forwards them to the browser.
// Retention sweep prunes these along with their parent jobs.
model LogChunk {
  id        String   @id @default(cuid())
  jobId     String
  seq       Int
  lines     String   // JSON string array
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, seq])
  @@index([jobId, seq])
}

model Metric {
  id            String   @id @default(cuid())
  serverId     String
  cpuPercent    Float
  memoryPercent Float
  diskPercent   Float
  createdAt     DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
}

// Hourly rollup of Metric rows so we can keep months of history without
// querying millions of points. Written by /api/internal/downsample once
// per completed hour, per server. The raw Metric table is then safe to
// prune (default: 14 days, see /api/internal/retention).
model MetricHourly {
  id            String   @id @default(cuid())
  serverId      String
  hourStart     DateTime
  cpuAvg        Float
  cpuMax        Float
  memoryAvg     Float
  memoryMax     Float
  diskAvg       Float
  diskMax       Float
  sampleCount   Int

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, hourStart])
  @@index([serverId, hourStart])
}

model Container {
  id        String   @id @default(cuid())
  serverId  String
  dockerId  String
  name      String
  image     String
  status    String
  // Stored as JSON string of an array like
  //   [{ "host": "8080", "container": "80", "protocol": "tcp" }]
  // SQLite has no native JSON type, so consumers must JSON.parse.
  ports     String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, dockerId])
  @@index([serverId])
}

model Alert {
  id        String   @id @default(cuid())
  serverId  String?
  type      String
  severity  String   @default("info")
  message   String
  resolved  Boolean       @default(false)
  createdAt DateTime      @default(now())

  server Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)

  @@index([resolved, createdAt])
}

// Dashboard users. Single-tenant for now: anyone with a User row gets full
// access to the UI. Multi-role / RBAC is on the roadmap.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions       Session[]
  invitesCreated Invite[]
}

// Single-use invite tokens. The plaintext token is shown to the inviting
// admin exactly once; only the SHA-256 hash is persisted. Accepting the
// invite marks `usedAt`; expired or used tokens are rejected.
model Invite {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  emailHint      String?
  expiresAt      DateTime
  usedAt         DateTime?
  createdByUserId String?
  createdAt      DateTime  @default(now())

  createdBy User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([expiresAt])
}

// Server-side sessions. The raw token lives only in the user's cookie; we
// store the SHA-256 hash so a DB leak can't be replayed.
model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

// Outbound notification channel. `type` selects the formatter/transport in
// src/lib/notifications.ts; `config` is a JSON string holding the
// type-specific options (URL, topic, token, etc.). Secrets are stored as-is
// — protect this DB the same way you'd protect /etc/secrets.
//
// type values:
//   "discord"  config = { webhookUrl }
//   "ntfy"     config = { server?, topic, token? }
//   "webhook"  config = { url, headers? }
model NotificationChannel {
  id            String    @id @default(cuid())
  name          String
  type          String
  config        String    @default("{}")
  enabled       Boolean   @default(true)
  // What severity levels trigger this channel: subset of "info,warning,critical".
  minSeverity   String    @default("warning")
  lastUsedAt    DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// AgentKey lets us rotate / scope agent credentials in the future. For MVP we
// also accept the env var AGENT_API_KEY as a fallback.
model AgentKey {
  id          String    @id @default(cuid())
  label       String
  keyHash     String    @unique
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
}
