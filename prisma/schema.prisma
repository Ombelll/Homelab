// Homelab Control Center — Prisma schema
// Runs on Postgres (migrated from SQLite). The database lives in CT 100 and
// the connection string comes from DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Server status is one of: "online" | "offline" | "warning" | "critical".
// Alert severity is one of: "info" | "warning" | "critical".
// Stored as plain strings because SQLite has no native enum type — values are
// validated at the API layer via Zod schemas.

model Server {
  id         String    @id @default(cuid())
  name       String
  hostname   String    @unique
  ipAddress  String?
  os         String?
  status     String    @default("offline")
  lastSeenAt DateTime?
  // Optional MAC address. When set, the dashboard exposes a Wake-on-LAN
  // button on the server detail. Format flexible (with/without colons).
  macAddress String?

  // System-level fields populated on agent checkin / metric tick.
  // bootAt: when the host last booted (computed from os.uptime()).
  // loadAvg: JSON of [1m, 5m, 15m]. Linux/macOS only; Windows reports [0,0,0].
  // networkRates: JSON of [{iface, rxBps, txBps}] — the rate between the
  //   last two agent ticks, computed agent-side from RX/TX byte deltas.
  // rebootRequired: true when the host has a pending reboot (e.g.
  //   /var/run/reboot-required on Debian, or the Windows CBS registry key).
  bootAt              DateTime?
  loadAvg             String?
  networkRates        String?
  // Per-device disk I/O bytes/sec for the last interval — JSON of
  // [{device, readBps, writeBps}]. Latest snapshot only, like networkRates.
  diskIoRates         String?
  // Top processes by CPU at the last tick — JSON of
  // [{pid, name, cpuPercent, memBytes}]. Latest snapshot only; not historised.
  topProcesses        String?
  // Age (hours) of the newest local backup the agent found (e.g. newest
  // vzdump in /tank/backups/dump). Only the host that owns the backups
  // reports it; drives the backup-stale alert. NULL on hosts without backups.
  backupAgeHours      Float?
  rebootRequired      Boolean   @default(false)
  rebootRequiredSince DateTime?

  // UPS state from NUT (`upsc`), reported only by the host wired to the UPS.
  // upsStatus is the raw NUT flag string ("OL" on mains, "OB" on battery,
  // "LB" low battery, etc). Drives the ups-on-battery alert. NULL = no UPS.
  upsName             String?
  upsStatus           String?
  upsBatteryPercent   Float?
  upsLoadPercent      Float?
  upsRuntimeSec       Int?
  upsInputVoltage     Float?
  upsUpdatedAt        DateTime?

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  metrics            Metric[]
  metricsHourly      MetricHourly[]
  containers         Container[]
  alerts             Alert[]
  jobs               Job[]
  disks              Disk[]
  sensors            Sensor[]
  maintenanceWindows MaintenanceWindow[]
  zfsPools           ZfsPool[]
  smartDevices       SmartDevice[]
}

// Physical-disk SMART health snapshot from the agent (smartctl). The agent
// scans block devices once per tick and upserts here; devices that disappear
// from the report are deleted (diffed in the API, like Disk/Sensor).
//
// healthy mirrors smartctl's overall PASSED/FAILED self-assessment. The rest
// are best-effort: not every drive/controller exposes every attribute, so all
// numeric fields are nullable.
model SmartDevice {
  id                String   @id @default(cuid())
  serverId          String
  device            String   // e.g. /dev/sda, /dev/nvme0n1
  model             String?
  serial            String?
  healthy           Boolean  @default(true)
  tempC             Float?
  powerOnHours      Int?
  reallocatedSectors Int?
  // SSD/NVMe media wear as a "percentage used" (0 = new, 100 = rated EOL).
  wearPercent       Int?
  updatedAt         DateTime @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, device])
  @@index([serverId])
}

// ZFS pool health snapshot. The agent reads `zpool list -H` plus
// `zpool status -x` once per tick and upserts here. Pools that disappear
// from the agent's report are deleted (e.g. a USB pool exported).
//
// health values: "ONLINE" | "DEGRADED" | "FAULTED" | "OFFLINE" | "UNAVAIL"
//   — we don't normalise; whatever zpool reports gets stored.
model ZfsPool {
  id          String    @id @default(cuid())
  serverId    String
  name        String
  health      String
  totalBytes  Float
  usedBytes   Float
  lastScrubAt DateTime?
  updatedAt   DateTime  @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, name])
  @@index([serverId])
}

// Job is a command the dashboard wants an agent to execute on a host. The
// dashboard inserts a row with status="pending"; the agent for that host
// claims it (status→"inflight") and later reports back (status→"done"|"error").
// This is how the dashboard performs container actions without ever touching
// Docker directly. See AGENTS.md → "Future Docker control flow".
//
// type values (one of):
//   "container.start" | "container.stop" | "container.restart" | "container.logs"
//
// payload / result are JSON strings; consumers must JSON.parse.
// Job statuses:
//   pending   — enqueued, no agent claimed it yet
//   inflight  — claimed and being executed
//   done      — agent reported success
//   error     — agent reported failure
//   cancel    — dashboard asked the agent to stop (long-running streams only)
//
// `cancel` is a control-plane signal: when the agent next tries to post a
// chunk we return continue=false and it tears down the process. Once the
// agent acknowledges, it sets the final status to "done".
model Job {
  id          String    @id @default(cuid())
  serverId    String
  type        String
  payload     String    @default("{}")
  status      String    @default("pending")
  result      String?
  createdAt   DateTime  @default(now())
  claimedAt   DateTime?
  completedAt DateTime?

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  chunks LogChunk[]

  @@index([serverId, status, createdAt])
}

// Buffered output from a streaming job (currently only container.logs.stream).
// The SSE endpoint reads new rows by `seq` and forwards them to the browser.
// Retention sweep prunes these along with their parent jobs.
model LogChunk {
  id        String   @id @default(cuid())
  jobId     String
  seq       Int
  lines     String   // JSON string array
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, seq])
  @@index([jobId, seq])
}

model Metric {
  id            String   @id @default(cuid())
  serverId     String
  cpuPercent    Float
  memoryPercent Float
  diskPercent   Float
  // Extended metrics — all nullable so older agents (and historical rows)
  // keep working. cpuPerCore is a JSON array of per-core percentages.
  swapPercent   Float?
  cpuPerCore    String?
  processCount  Int?
  failedUnits   Int?
  // Scalar aggregates derived server-side from the tick's network/disk-I/O
  // rate arrays and temperature sensors, kept here so they can be charted as
  // a time series without storing per-iface/per-device/per-sensor history.
  // netBps/diskBps are total throughput (read+write / rx+tx) in bytes/sec.
  netBps        Float?
  diskBps       Float?
  maxTempC      Float?
  createdAt     DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
}

// Hourly rollup of Metric rows so we can keep months of history without
// querying millions of points. Written by /api/internal/downsample once
// per completed hour, per server. The raw Metric table is then safe to
// prune (default: 14 days, see /api/internal/retention).
model MetricHourly {
  id            String   @id @default(cuid())
  serverId      String
  hourStart     DateTime
  cpuAvg        Float
  cpuMax        Float
  memoryAvg     Float
  memoryMax     Float
  diskAvg       Float
  diskMax       Float
  // Extended rollups — nullable so existing rows and the first runs after a
  // schema bump stay valid. Mirror the scalar Metric extras.
  swapAvg       Float?
  swapMax       Float?
  netBpsAvg     Float?
  netBpsMax     Float?
  diskBpsAvg    Float?
  diskBpsMax    Float?
  tempMax       Float?
  sampleCount   Int

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, hourStart])
  @@index([serverId, hourStart])
}

model Container {
  id        String   @id @default(cuid())
  serverId  String
  dockerId  String
  name      String
  image     String
  status    String

  // Docker healthcheck state parsed from `docker ps` ("healthy" | "unhealthy"
  // | "starting"). NULL when the image declares no HEALTHCHECK. An "unhealthy"
  // value (or a "restarting" status) raises a container-unhealthy alert.
  health    String?

  // Image digest tracking for "update available" notifications. The agent
  // reads `ImageID` (the local sha256) from `docker inspect`; a separate
  // sweep fetches the remote manifest digest and flips updateAvailable.
  imageDigest      String?
  remoteDigest     String?
  updateAvailable  Boolean  @default(false)
  lastUpdateCheck  DateTime?
  // Stored as JSON string of an array like
  //   [{ "host": "8080", "container": "80", "protocol": "tcp" }]
  // SQLite has no native JSON type, so consumers must JSON.parse.
  ports     String   @default("[]")

  // Compose grouping (from the standard docker-compose labels). NULL when
  // the container was started outside of compose.
  composeProject String?
  composeService String?

  // Last-known per-container resource usage from `docker stats`.
  cpuPercent       Float?
  memoryBytes      Float?
  memoryLimitBytes Float?
  statsAt          DateTime?

  // Total restarts since the container was created. The agent reads this
  // from `docker inspect --format '{{.RestartCount}}'`. A spike here is a
  // crashloop; the UI surfaces a badge once it crosses a threshold.
  restartCount     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, dockerId])
  @@index([serverId])
  @@index([serverId, composeProject])
}

// Per-filesystem usage from the agent. The agent enumerates non-pseudo
// mountpoints on each tick and upserts here. Removed when the agent stops
// reporting them (handled by a diff in the API).
model Disk {
  id         String   @id @default(cuid())
  serverId   String
  mountpoint String
  fstype     String?
  totalBytes Float
  usedBytes  Float
  updatedAt  DateTime @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, mountpoint])
  @@index([serverId])
}

// Generic numeric readings from the host (temperatures, fan RPM, power
// draw). Agents that can't read sensors simply don't send any rows.
model Sensor {
  id        String   @id @default(cuid())
  serverId  String
  name      String
  kind      String   // "temperature" | "fan" | "power" | other
  value     Float
  unit      String
  updatedAt DateTime @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, name])
  @@index([serverId])
}

// Suppress alert creation + notifications for a window of time. serverId=NULL
// means a global maintenance (e.g. dashboard upgrade); otherwise scoped to
// one host.
model MaintenanceWindow {
  id        String   @id @default(cuid())
  serverId  String?
  reason    String?
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())

  server Server? @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([startsAt, endsAt])
}

// External service-level checks (HTTP / TCP / ping). The dashboard's host
// runs these on a schedule; results are stored back here and feed the
// alert engine when status flips to "down".
model HealthCheck {
  id              String    @id @default(cuid())
  name            String
  type            String    // "http" | "tcp" | "ping"
  target          String    // URL for http, host:port for tcp, host for ping
  intervalSeconds Int       @default(60)
  timeoutMs       Int       @default(5000)
  expectedStatus  Int?      // optional override for HTTP (default: any 2xx)
  enabled         Boolean   @default(true)
  lastStatus      String?   // "up" | "down" | NULL when never run
  lastLatencyMs   Int?
  lastCheckedAt   DateTime?
  lastError       String?
  consecutiveDown Int       @default(0)
  // For type "tls": the peer certificate's notAfter. Used to alert ahead of
  // expiry. NULL for non-tls checks or when never probed.
  certExpiresAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Alert {
  id        String   @id @default(cuid())
  serverId  String?
  type      String
  severity  String   @default("info")
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  // Acknowledgment: clicking "ack" stops future severity-upgrade
  // notifications on this alert. Does not resolve the alert.
  acknowledgedAt       DateTime?
  acknowledgedByUserId String?

  // Snooze: while snoozedUntil is in the future, no notifications fire for
  // changes on this alert. Resolution still happens automatically.
  snoozedUntil DateTime?

  server         Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  acknowledgedBy User?   @relation(fields: [acknowledgedByUserId], references: [id], onDelete: SetNull)

  @@index([resolved, createdAt])
}

// Dashboard users.
//   role = "admin"  → full read/write across the dashboard
//   role = "viewer" → read-only: no container actions, no settings changes
//
// The bootstrap user (first registration) is always created as "admin".
// Subsequent users are created via Invite and inherit the invite's role.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         String    @default("admin")
  // Optional TOTP two-factor. totpSecret holds the base32 secret (only set
  // once 2FA is enabled). recoveryCodes is a JSON array of sha256-hashed
  // single-use backup codes. Login is unchanged unless totpEnabled is true.
  totpSecret    String?
  totpEnabled   Boolean  @default(false)
  recoveryCodes String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions           Session[]
  invitesCreated     Invite[]
  alertsAcknowledged Alert[]
}

// Single-use invite tokens. The plaintext token is shown to the inviting
// admin exactly once; only the SHA-256 hash is persisted. Accepting the
// invite marks `usedAt`; expired or used tokens are rejected.
model Invite {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  emailHint      String?
  role           String    @default("viewer")
  expiresAt      DateTime
  usedAt         DateTime?
  createdByUserId String?
  createdAt      DateTime  @default(now())

  createdBy User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([expiresAt])
}

// Server-side sessions. The raw token lives only in the user's cookie; we
// store the SHA-256 hash so a DB leak can't be replayed.
model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

// Outbound notification channel. `type` selects the formatter/transport in
// src/lib/notifications.ts; `config` is a JSON string holding the
// type-specific options (URL, topic, token, etc.). Secrets are stored as-is
// — protect this DB the same way you'd protect /etc/secrets.
//
// type values:
//   "discord"  config = { webhookUrl }
//   "ntfy"     config = { server?, topic, token? }
//   "webhook"  config = { url, headers? }
model NotificationChannel {
  id            String    @id @default(cuid())
  name          String
  type          String
  config        String    @default("{}")
  enabled       Boolean   @default(true)
  // What severity levels trigger this channel: subset of "info,warning,critical".
  minSeverity   String    @default("warning")
  lastUsedAt    DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// AgentKey lets us rotate / scope agent credentials. We also accept the env
// var AGENT_API_KEY as a global fallback.
//
// hostname binding: when non-NULL, the key only authenticates requests
// whose body specifies this exact hostname. This means a leaked per-host
// key cannot impersonate a different host.
model AgentKey {
  id          String    @id @default(cuid())
  label       String
  keyHash     String    @unique
  hostname    String?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
}

// Append-only record of admin / sensitive actions, for after-the-fact
// review. Read by the Settings → Audit log panel; pruned by the retention
// sweep along with the rest.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  actorEmail String? // denormalised so logs survive user deletion
  action    String
  target    String?  // e.g. "container:abc123", "user:xyz"
  metadata  String?  // JSON string
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([userId])
}

// A network device polled over SNMP (e.g. a managed switch). Unlike Server,
// it has no agent of its own — one of the agents on the LAN polls it via SNMP
// and reports here. Identified by the target IP/host the agent polled.
model NetworkDevice {
  id         String    @id @default(cuid())
  host       String    @unique // IP/hostname the agent polled (e.g. 192.168.1.x)
  name       String // sysName from SNMP, or a friendly fallback
  vendor     String? // sysDescr snippet, optional
  uptimeSec  Int? // sysUpTime in seconds
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  ports NetworkPort[]
}

// One physical/logical interface of a NetworkDevice. Throughput is the
// bytes/sec rate the agent computed from the SNMP octet-counter delta between
// polls (like the host network/disk-IO rates). Rows for ports that vanish from
// a poll are deleted (diffed in the ingest route).
model NetworkPort {
  id        String   @id @default(cuid())
  deviceId  String
  ifIndex   Int
  name      String // ifName/ifDescr, e.g. "Gi1/0/1"
  status    String // "up" | "down" | other ifOperStatus text
  adminUp   Boolean? // ifAdminStatus == up (admin-down distinguishes disabled from broken)
  speedMbps Int? // ifHighSpeed in Mbit/s; 0 when down
  rxBps     Float? // inbound bytes/sec
  txBps     Float? // outbound bytes/sec
  inErrors  Int? // ifInErrors counter (cumulative)
  outErrors Int? // ifOutErrors counter (cumulative)
  inDiscards  Int? // ifInDiscards counter (cumulative)
  outDiscards Int? // ifOutDiscards counter (cumulative)
  // New errors+discards since the previous poll (computed dashboard-side from
  // the counter delta). This is what the UI shows and the switch alert uses —
  // a cumulative lifetime total is meaningless for spotting a problem now.
  errDelta  Int?
  updatedAt DateTime @updatedAt

  device NetworkDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, ifIndex])
  @@index([deviceId])
}
